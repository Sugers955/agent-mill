# 根目录部署配置（含真实密码，绝不提交）
.env

backend/__pycache__/
backend/**/__pycache__/
backend/.env
backend/.env.local
backend/*.egg-info/
backend/.venv/
backend/.pytest_cache/

frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env.local

# IDE local-history snapshots (VS Code "Local History" extension).
# Not meant for version control — they often contain intermediate/secret values.
.history/
.vscode/
.idea/

storage/uploads/*
!storage/uploads/.gitkeep
storage/skills/*
!storage/skills/.gitkeep
storage/outputs/*
.DS_Store
*.log

# Generic secrets safety net
*.pem
*.key
secrets.json
.secrets/
