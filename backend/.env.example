# Database
DATABASE_URL=postgresql+asyncpg://h3c:h3c@localhost:5432/h3c_agent

# Auth
JWT_SECRET=change-me-in-production-please
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key (Fernet, base64 32 bytes). Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Storage
STORAGE_ROOT=../storage
SKILLS_DIR=../storage/skills
UPLOADS_DIR=../storage/uploads
MAX_UPLOAD_MB=50

# CORS
CORS_ORIGINS=http://localhost:5173

# Default admin (created by seed script if missing)
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
