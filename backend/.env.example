# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit it.

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://h3c:h3c@localhost:5432/h3c_agent

# ---- Auth ----
# 32+ random bytes. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-please
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet key for encrypting model API keys in DB (base64 32 bytes).
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# If blank in dev, a key is derived from JWT_SECRET — do NOT rely on that in prod.
ENCRYPTION_KEY=

# ---- Storage ----
STORAGE_ROOT=../storage
SKILLS_DIR=../storage/skills
UPLOADS_DIR=../storage/uploads
MAX_UPLOAD_MB=50

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173

# ---- First-run admin (change immediately after first login) ----
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# ---- File parsing (MinerU). Mode: cloud | local | disabled ----
MINERU_MODE=cloud
MINERU_BASE_URL=https://mineru.net
MINERU_API_KEY=
MINERU_TIMEOUT_SEC=60
PARSED_MARKDOWN_HARD_LIMIT=20000

# ---- SMTP (task notifications). Leave blank to disable email. ----
# For QQ mail: SMTP_HOST=smtp.qq.com, SMTP_PORT=587, SMTP_USE_TLS=true.
# Generate an "authorization code" (not the account password) in QQ Mail settings.
# SMTP_FROM format: "Display Name <addr@host>" — for QQ, the address MUST equal SMTP_USER.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
APP_BASE_URL=http://localhost:5173
