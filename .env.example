# ============================================================
# Agent Mill 环境配置
# 使用方式: cp .env.example .env && 编辑 .env
# ============================================================

# ── 数据库 ──
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3307
DB_USER=agent_mill
DB_PASSWORD=changeme
DB_NAME=agent_mill

# ── 认证密钥（必填，必须修改） ──
# 生成命令: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=changeme-random-secret-key

# 生成命令: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── 管理员账号（首次登录后请立即修改密码） ──
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# ── 模型 API Key（至少配置一个） ──
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx

# ── 端口配置 ──
WEB_PORT=80
API_PORT=8000

# ── 应用地址（用于 CORS 和回调） ──
APP_BASE_URL=http://localhost
