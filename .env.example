# ============================================================
# Docker Compose 部署配置 — 所有服务共用
# 使用方式: cp .env.example .env 然后填写真实值
# .env 已在 .gitignore 中，绝不提交
# ============================================================

# ---- 数据库 ----
DB_USER=h3c
DB_PASSWORD=change-me-secure-password
DB_NAME=h3c_agent

# ---- 端口 ----
WEB_PORT=80
API_PORT=8000

# ---- 域名 / 访问地址 ----
# 填写服务器 IP 或域名，用于 CORS 和邮件回链
# 示例: http://192.168.1.100  或  https://agent.example.com
APP_BASE_URL=http://your-server-ip

# ---- 鉴权 ----
# 生成随机 secret: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-32-plus-random-bytes
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=2

# ---- 加密 (存储模型 API Key 用) ----
# 生成: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 留空则从 JWT_SECRET 派生（开发可用，生产必须显式设置）
ENCRYPTION_KEY=

# ---- 初始管理员 ----
# 首次登录后立即在管理界面修改密码！
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-admin-password

# ---- 文件存储 ----
MAX_UPLOAD_MB=50
PARSED_MARKDOWN_HARD_LIMIT=20000

# ---- MinerU 文档解析 ----
# Mode: cloud | local | disabled
MINERU_MODE=cloud
MINERU_BASE_URL=https://mineru.net
# 去 https://mineru.net 注册申请 token
MINERU_API_KEY=
MINERU_TIMEOUT_SEC=60

# ---- SMTP 邮件通知 (可选，全部留空则禁用邮件) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
